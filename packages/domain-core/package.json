{
  "name": "@mindease/domain",
  "version": "1.0.0",
  "description": "Domain core library - Entities, Interfaces and Use Cases (Pure TypeScript)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*",
      "require": "./dist/*",
      "types": "./dist/*.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "test": "echo 'No tests configured yet'",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
  }
}
