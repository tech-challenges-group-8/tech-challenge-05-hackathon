{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "../.."
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../packages/domain-core/src/**/*.ts",
    "../../packages/shared-dtos/src/**/*.ts",
    "../../packages/ui-kit/src/**/*.ts",
    "../../packages/ui-kit/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
