{
  "name": "mindease-mobile",
  "version": "1.0.0",
  "description": "Mobile app - React Native with Expo",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@mindease/domain": "workspace:*",
    "@mindease/dtos": "workspace:*",
    "@mindease/ui-kit": "workspace:*",
    "expo": "^50.0.0",
    "expo-constants": "^15.3.0",
    "expo-status-bar": "~1.10.0",
    "react": "^18.2.0",
    "react-native": "^0.73.2",
    "react-native-windows": "^0.73.4",
    "nativewind": "^2.0.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@types/jest": "^29.5.8",
    "@types/react": "^18.2.45",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  }
}
