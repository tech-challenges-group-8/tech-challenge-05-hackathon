{
  "name": "mindease-monorepo",
  "version": "1.0.0",
  "description": "MindEase - A mental health support platform (Monorepo with Turborepo)",
  "license": "MIT",
  "private": true,
  "author": "Your Name",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:app": "pnpm --parallel --filter='./apps/*' run dev",
    "dev:backend": "pnpm --filter=./apps/backend run start:dev",
    "dev:web": "pnpm --filter=./apps/web run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.3",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "@typescript-eslint/parser": "^6.13.2",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "prettier": "^3.1.0",
    "@types/node": "^20.10.5"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.3"
    }
  }
}
